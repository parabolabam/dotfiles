#!/usr/bin/env bash
set -euo pipefail

cur="$(tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}')"
tab=$'\t'
fmt="#{session_name}:#{window_index}.#{pane_index}${tab}#{session_name}:#{window_index}${tab}#{window_name}${tab}#{pane_current_command}${tab}#{pane_current_path}"

tmux list-panes -a -F "$fmt" | awk -F'\t' -v c="$cur" '
  $1 == c { print; next }
  { buf = buf $0 ORS }
  END { printf "%s", buf }
'
